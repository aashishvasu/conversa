# Required
ANTHROPIC_API_KEY=sk-ant-...
APP_PASSWORD=change-me

# Session token signing. Optional: if unset, a random key is generated each start
# (restart = everyone re-logs-in). Set it to keep sessions across restarts.
JWT_SECRET=
TOKEN_TTL_SECONDS=604800

# Global setting defaults (client copies these into new conversations)
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_TEMPERATURE=1.0
DEFAULT_NUM_MESSAGES=20
DEFAULT_SEND_SYSTEM_PROMPT=true
DEFAULT_MAX_TOKENS=4096
# Cheap model for auxiliary tasks: conversation titles and history compression.
DEFAULT_UTILITY_MODEL=claude-haiku-4-5
# History compression: summarize old turns into "memory" once the unsummarized
# tail exceeds this many characters. Sent (when enabled) inside the system prompt.
DEFAULT_USE_MEMORY=false
DEFAULT_COMPRESSION_THRESHOLD=4000

# Selectable models shown in the UI. Format: id:Label,id2:Label2 (label optional).
MODELS=claude-sonnet-4-6:Sonnet 4.6,claude-opus-4-8:Opus 4.8,claude-haiku-4-5:Haiku 4.5

# Dev only: allow the Vite origin. Prod serves the SPA same-origin so this is unused.
CORS_ORIGINS=http://localhost:5173
